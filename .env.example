# Fart Counter — Environment Variables
# Этот файл — пример. Скопируйте его в .env и заполните значениями.
# На Vercel переменные добавляются через Settings → Environment Variables.

# Приложение работает без переменных — это полностью офлайн PWA.
# Все данные хранятся в localStorage браузера пользователя.

# (зарезервировано для будущих функций)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
